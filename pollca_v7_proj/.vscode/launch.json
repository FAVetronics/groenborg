    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/pollca_v7/bin/Debug/net8.0/pollca_v7.dll",
            "args": ["COM11", "http://comforttan-dev.vsrv111.vmc1.systemina.dk/api/machine/32/callback", "Y", "3000"], // <--- Add your parameters here
            "cwd": "${workspaceFolder}",
            "console": "internalConsole",
            "stopAtEntry": false,
            "justMyCode": true,
            "logging": {
                "moduleLoad": false,
                "exceptions": true,
                "programOutput": true,
                "engineLogging": false,
                "browserStdOut": false
            }
        }
    ]
}
